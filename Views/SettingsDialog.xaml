<Window x:Class="Hanime1Downloader.CSharp.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Width="480"
        Height="480"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#F6F6F6">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#C8D0DA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#1677FF"/>
            <Setter Property="BorderBrush" Value="#1677FF"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="7,0"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="5,0"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="72"/>
        </Style>
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20,16,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <!-- 下载目录 -->
            <DockPanel Margin="0,0,0,12">
                <TextBlock Style="{StaticResource LabelStyle}" Text="下载目录"/>
                <Button DockPanel.Dock="Right" Width="60" Margin="8,0,0,0" Click="BrowseButton_OnClick" Content="浏览"/>
                <TextBox x:Name="DownloadPathBox"/>
            </DockPanel>

            <!-- 访问站点 -->
            <DockPanel Margin="0,0,0,12">
                <TextBlock Style="{StaticResource LabelStyle}" Text="访问站点"/>
                <ComboBox x:Name="SiteCombo" DisplayMemberPath="Label" SelectedValuePath="Value"/>
            </DockPanel>

            <!-- 命名规则 -->
            <DockPanel Margin="0,0,0,12">
                <TextBlock Style="{StaticResource LabelStyle}" Text="命名规则"/>
                <ComboBox x:Name="NamingRuleCombo" DisplayMemberPath="Label" SelectedValuePath="Value"/>
            </DockPanel>

            <!-- 默认画质 -->
            <DockPanel Margin="0,0,0,12">
                <TextBlock Style="{StaticResource LabelStyle}" Text="默认画质"/>
                <ComboBox x:Name="QualityCombo" DisplayMemberPath="Label" SelectedValuePath="Value"/>
            </DockPanel>

            <!-- 列表封面 -->
            <DockPanel Margin="0,0,0,12">
                <TextBlock Style="{StaticResource LabelStyle}" Text="列表封面"/>
                <CheckBox x:Name="ShowListCoversCheckBox" Content="显示搜索结果和收藏夹封面"/>
            </DockPanel>

            <!-- 精简模式 -->
            <DockPanel Margin="0,0,0,12">
                <TextBlock Style="{StaticResource LabelStyle}" Text="精简模式"/>
                <CheckBox x:Name="CompactModeCheckBox" Content="隐藏详情面板，双击搜索结果直接入队"/>
            </DockPanel>

            <!-- 队列持久化 -->
            <DockPanel Margin="0,0,0,16">
                <TextBlock Style="{StaticResource LabelStyle}" Text="下载队列"/>
                <CheckBox x:Name="PersistQueueCheckBox" Content="关闭程序后保留下载队列"/>
            </DockPanel>

            <!-- 视频信息显示项 -->
            <Border Padding="14,12" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="视频信息显示项"/>
                    <UniformGrid Columns="3" HorizontalAlignment="Left">
                        <CheckBox x:Name="ShowTitleCheckBox"       Margin="0,0,16,8" Content="标题"/>
                        <CheckBox x:Name="ShowUploadDateCheckBox"  Margin="0,0,16,8" Content="上传日期"/>
                        <CheckBox x:Name="ShowLikesCheckBox"       Margin="0,0,16,8" Content="点赞"/>
                        <CheckBox x:Name="ShowViewsCheckBox"       Margin="0,0,16,8" Content="观看次数"/>
                        <CheckBox x:Name="ShowDurationCheckBox"    Margin="0,0,16,8" Content="时长"/>
                        <CheckBox x:Name="ShowTagsCheckBox"        Margin="0,0,16,8" Content="标签"/>
                        <CheckBox x:Name="ShowCoverCheckBox"       Margin="0,0,16,8" Content="封面按钮"/>
                        <CheckBox x:Name="ShowRelatedVideosCheckBox" Margin="0,0,16,0" Content="相关视频"/>
                    </UniformGrid>
                </StackPanel>
            </Border>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,16,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Width="80" IsDefault="True" Click="ConfirmButton_OnClick" Content="确定" Style="{StaticResource PrimaryButtonStyle}"/>
            <Button Width="80" Margin="8,0,0,0" IsCancel="True" Content="取消"/>
        </StackPanel>
    </Grid>
</Window>
