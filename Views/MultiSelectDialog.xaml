<Window x:Class="Hanime1Downloader.CSharp.Views.MultiSelectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择"
        Width="760"
        Height="680"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#F6F6F6">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#C8D0DA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#1677FF"/>
            <Setter Property="BorderBrush" Value="#1677FF"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="7,0"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#374151"/>
        </Style>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="PromptText"
                   Foreground="#374151"
                   FontSize="12"
                   TextWrapping="Wrap"/>

        <TextBox x:Name="SearchBox"
                 Grid.Row="1"
                 Margin="0,6,0,0"
                 Height="28"
                 VerticalContentAlignment="Center"
                 Padding="7,0"
                 TextChanged="SearchBox_OnTextChanged"
                 KeyDown="SearchBox_OnKeyDown"/>

        <DockPanel Grid.Row="2"
                   Margin="0,6,0,0"
                   LastChildFill="False">
            <TextBlock x:Name="SelectionSummaryText"
                       VerticalAlignment="Center"
                       FontSize="11"
                       Foreground="#6B7280"/>
            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal">
                <Button x:Name="SelectVisibleButton"
                        Width="84"
                        Click="SelectVisibleButton_OnClick"
                        Content="全选结果"/>
                <Button x:Name="ClearVisibleButton"
                        Width="84"
                        Margin="6,0,0,0"
                        Click="ClearVisibleButton_OnClick"
                        Content="清空结果"/>
            </StackPanel>
        </DockPanel>

        <ScrollViewer x:Name="GroupScrollViewer"
                      Grid.Row="3"
                      Margin="0,6,0,0"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="GroupHost"/>
        </ScrollViewer>

        <StackPanel Grid.Row="4"
                    Margin="0,8,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Width="80"
                    Click="ResetButton_OnClick"
                    Content="重置"/>
            <Button Width="80"
                    Margin="6,0,0,0"
                    IsDefault="True"
                    Click="ConfirmButton_OnClick"
                    Content="确定"
                    Style="{StaticResource PrimaryButtonStyle}"/>
            <Button Width="80"
                    Margin="6,0,0,0"
                    IsCancel="True"
                    Content="取消"/>
        </StackPanel>
    </Grid>
</Window>
