<Window x:Class="Hanime1Downloader.CSharp.Views.FilterDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="筛选设置"
        Width="420"
        Height="460"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#F8F9FA">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F3F4F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#1677FF"/>
            <Setter Property="BorderBrush" Value="#1677FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0E6AE0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="Foreground" Value="#374151"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20,16,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Style="{StaticResource LabelStyle}" Text="影片类型"/>
            <ComboBox x:Name="GenreCombo" Margin="0,0,0,12"
                      DisplayMemberPath="Label" SelectedValuePath="Value"
                      SelectionChanged="QuickFilterControl_OnChanged"/>

            <TextBlock Style="{StaticResource LabelStyle}" Text="排序方式"/>
            <ComboBox x:Name="SortCombo" Margin="0,0,0,12"
                      DisplayMemberPath="Label" SelectedValuePath="Value"
                      SelectionChanged="QuickFilterControl_OnChanged"/>

            <TextBlock Style="{StaticResource LabelStyle}" Text="发布日期"/>
            <ComboBox x:Name="DateCombo" Margin="0,0,0,12"
                      DisplayMemberPath="Label" SelectedValuePath="Value"
                      SelectionChanged="QuickFilterControl_OnChanged"/>

            <TextBlock Style="{StaticResource LabelStyle}" Text="时长"/>
            <ComboBox x:Name="DurationCombo" Margin="0,0,0,16"
                      DisplayMemberPath="Label" SelectedValuePath="Value"
                      SelectionChanged="QuickFilterControl_OnChanged"/>

            <!-- 标签 -->
            <Border Padding="12,10" Background="#FFFFFF" BorderBrush="#E5E7EB"
                    BorderThickness="1" CornerRadius="6" Margin="0,0,0,16">
                <DockPanel>
                    <Button DockPanel.Dock="Right" Width="72" VerticalAlignment="Top"
                            Click="ChooseTagsButton_OnClick" Content="选择标签"/>
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#111827"
                                   Text="标签" Margin="0,0,0,6"/>
                        <Button x:Name="TagsSummaryButton" Padding="0" HorizontalAlignment="Left"
                                Background="Transparent" BorderThickness="0"
                                Click="ChooseTagsButton_OnClick" Cursor="Hand">
                            <TextBlock x:Name="TagsSummaryText" FontSize="11"
                                       Foreground="#6B7280" TextWrapping="Wrap"/>
                        </Button>
                    </StackPanel>
                </DockPanel>
            </Border>

            <DockPanel>
                <CheckBox x:Name="BroadCheckBox" VerticalAlignment="Center"
                          Checked="QuickFilterControl_OnChanged"
                          Unchecked="QuickFilterControl_OnChanged"
                          Content="广泛配对"/>
                <TextBlock x:Name="FilterStateText" DockPanel.Dock="Right"
                           VerticalAlignment="Center" HorizontalAlignment="Right"
                           Foreground="#9CA3AF" FontSize="11"
                           Text="当前未启用额外筛选"/>
            </DockPanel>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,16,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Width="72" Click="ResetButton_OnClick" Content="重置"/>
            <Button Width="72" Margin="8,0,0,0" IsDefault="True"
                    Click="ConfirmButton_OnClick" Content="确定"
                    Style="{StaticResource PrimaryButtonStyle}"/>
            <Button Width="72" Margin="8,0,0,0" IsCancel="True" Content="取消"/>
        </StackPanel>
    </Grid>
</Window>
